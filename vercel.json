{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/update-retail-prices",
      "schedule": "0 0 * * 0"
    },
    {
      "path": "/api/cron/update-ebay-prices",
      "schedule": "0 2 * * 0"
    }
  ]
}